# Copy to .env and replace placeholder values before starting the stack.

BRIGADE_BIND_ADDRESS=127.0.0.1
BRIGADE_STALE_WORK_SECONDS=86400

BRIGADE_POSTGRES_DB=brigade
BRIGADE_POSTGRES_USER=brigade
BRIGADE_POSTGRES_PASSWORD=change-me
BRIGADE_POSTGRES_PORT=55432

BRIGADE_REDIS_PORT=56379

BRIGADE_QDRANT_HTTP_PORT=56333
BRIGADE_QDRANT_GRPC_PORT=56334
BRIGADE_QDRANT_COLLECTION=brigade_episodes_nomic_embed_text

BRIGADE_NEO4J_AUTH=neo4j/change-me
BRIGADE_NEO4J_HTTP_PORT=57474
BRIGADE_NEO4J_BOLT_PORT=57687
BRIGADE_NEO4J_HEAP_INITIAL=512m
BRIGADE_NEO4J_HEAP_MAX=1G

BRIGADE_JWT_SECRET=replace-with-a-long-random-secret
BRIGADE_JWT_ISSUER=openbrigade-local
BRIGADE_JWT_AUDIENCE=openbrigade
BRIGADE_REQUIRE_AUTH=false
BRIGADE_WEB_PORT=58080

BRIGADE_OLLAMA_BASE_URL=http://host.docker.internal:11434
BRIGADE_DEFAULT_PROVIDER=ollama
BRIGADE_DEFAULT_MODEL=gpt-oss:20b
# If your embedding Ollama instance runs on a different port (e.g. a dedicated
# GPU), set BRIGADE_OLLAMA_EMBEDDING_BASE_URL to that address independently of
# BRIGADE_OLLAMA_BASE_URL.  Both default to port 11434 if unset.
BRIGADE_OLLAMA_EMBEDDING_BASE_URL=http://host.docker.internal:11434
BRIGADE_OLLAMA_EMBEDDING_MODEL=nomic-embed-text:latest
BRIGADE_OLLAMA_EMBEDDING_VECTOR_SIZE=768
BRIGADE_OLLAMA_PROXY_LISTEN_HOST=172.17.0.1
BRIGADE_OLLAMA_PROXY_PORT=11434
BRIGADE_OLLAMA_PROXY_TARGET_HOST=127.0.0.1
BRIGADE_OLLAMA_PROXY_TARGET_PORT=11434
# Chief-chat runs a multi-turn tool loop, so its prompts grow ~1-2KB per
# iteration (history + notes + observations). Give Ollama a real context
# window or long turns silently degrade to empty replies. 16384 is the
# built-in default; raise it if you run many iterations or a large history.
BRIGADE_OLLAMA_NUM_CTX=16384

# Chief chat (release 1.1): converse with per-team Crew Chiefs or the
# fleet-wide front desk in natural language. Enabled for the web/mobile UI by
# default; routing external connectors (Telegram, Google Chat) through it is a
# separate opt-in while it soaks.
BRIGADE_CHIEF_CHAT_ENABLED=true
BRIGADE_CHIEF_CHAT_MAX_ITERATIONS=6
BRIGADE_CHIEF_CHAT_HISTORY_WINDOW=12
# auto: a single-chief fleet talks to that chief, otherwise the front desk.
BRIGADE_CHIEF_CHAT_DEFAULT_PERSONA=auto
BRIGADE_CONNECTOR_CHIEF_CHAT_ENABLED=false
BRIGADE_CHIEF_CHAT_CONNECTOR_MAX_ITERATIONS=3

# To route orchestration and agent defaults through OpenAI/Codex instead of Ollama:
# OPENAI_API_KEY=replace-with-openai-api-key
# BRIGADE_DEFAULT_PROVIDER=openai-codex
# BRIGADE_DEFAULT_MODEL=gpt-5.4
# BRIGADE_OPENAI_CODEX_AUTH_MODE=api_key
#
# OAuth/manual-token route for OpenAI/Codex:
# BRIGADE_DEFAULT_PROVIDER=openai-codex
# BRIGADE_DEFAULT_MODEL=gpt-5.4
# BRIGADE_OPENAI_CODEX_AUTH_MODE=oauth
# Then import a token locally with:
#   ./ops/brigade-live.sh model auth login --provider openai-codex --method oauth --access-token-stdin
#
# Existing agents keep their persisted route until updated:
#   ./ops/brigade-live.sh agent model --id <agent-id> --provider openai-codex --model gpt-5.4
